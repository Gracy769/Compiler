{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["tables"],
  "properties": {
    "tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "columns"],
        "properties": {
          "name": {"type": "string"},
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": {"type": "string"},
                "type": {"type": "string", "enum": ["INTEGER", "TEXT", "REAL", "BOOLEAN", "BLOB", "TIMESTAMP", "VARCHAR", "UUID"]},
                "primary_key": {"type": "boolean"},
                "auto_increment": {"type": "boolean"},
                "unique": {"type": "boolean"},
                "nullable": {"type": "boolean"},
                "default": {},
                "references": {
                  "type": "object",
                  "properties": {
                    "table": {"type": "string"},
                    "column": {"type": "string"},
                    "on_delete": {"type": "string", "enum": ["CASCADE", "SET NULL", "RESTRICT"]}
                  }
                }
              }
            }
          },
          "indexes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "columns": {"type": "array", "items": {"type": "string"}},
                "unique": {"type": "boolean"}
              }
            }
          }
        }
      }
    }
  }
}